{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "isolatedModules": true,
    "resolveJsonModule": true
  },
  "include": ["api/**/*.ts"]
}
