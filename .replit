run = "npm start"
entrypoint = "src/migrate/server.ts"
hidden = ["node_modules", ".config", ".git", "migrations", "samples", ".viewer", ".auth", "dist"]
modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "npm start"]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm ci --omit=dev"]
ignorePorts = false

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8765
externalPort = 80

[env]
HOSTED_DEPLOY = "1"

[agent]
integrations = ["javascript_anthropic_ai_integrations:2.0.0"]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx tsx src/migrate/server.ts 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
